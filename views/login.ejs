<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/login.css">
</head>

<body>
    <form id="login-form" method="POST" action="/submit">
        <div id="login-form-div">
            <i id="logo" class="fa-brands fa-airbnb"></i>
            <br>
            <br>
            <!-- <img src="" alt="img"> -->
            <h3>Hi Welcome Back!</h3>
            <br>
            <h4>Enter Your Account Details</h4>
            <br>
            <input required id="login-email" type="email" name="user-email" placeholder="Enter Your Email">
            <br>
            <br>
            <input minlength="6" required id="login-password" type="password" name="user-password" placeholder="Enter Your Password">
            <p>Password must be 6 char long </p>
            <br>
            <br>
            <button type="submit">Login</button>
            <br>
            <br>
            <p>Don't have a account ? <a href="#">Create One!</a></p>


        </div>






    </form>

    <%- include("./layouts/footer.ejs") %>

</body>

</html>